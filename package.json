{
  "name": "veem-cli",
  "version": "1.1.0",
  "description": "CLI to provision VMs and deploy apps with zero-downtime",
  "author": "scott-mccartney",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "veem": "./dist/index.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scott-mccartney/veem.git"
  },
  "keywords": [
    "veem",
    "vm",
    "docker",
    "startup",
    "setup"
  ],
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); const f='dist/index.js'; fs.writeFileSync(f, '#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));\"",
    "dev": "ts-node src/index.ts"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "node-ssh": "^13.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}